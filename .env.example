# ===== zenmux API =====
# 【生图用】调用模型的 API Key(sk-ai-v1-... 或 sk-ss-v1-...)
ZENMUX_API_KEY=sk-your-zenmux-key

# 【查余额用】Management API Key(sk-mg-v1-...),只读,用于在管理页显示服务器余额/订阅配额
# 在 ZenMux 控制台 > Management 创建。不填则管理页不显示服务器状态。
ZENMUX_MANAGEMENT_KEY=sk-mg-v1-your-management-key

# zenmux 接口基础地址(一般无需改)
# OpenAI 兼容协议基址(gpt-image-2 等走这里)
ZENMUX_OPENAI_BASE=https://zenmux.ai/api/v1
# Google/Gemini 兼容协议基址(banana 系列走这里)
ZENMUX_GEMINI_BASE=https://zenmux.ai/api/vertex-ai/v1

# ===== 站点 =====
# 监听端口
PORT=3000
# session 加密密钥,部署前改成一串随机长字符串
SESSION_SECRET=change-me-to-a-long-random-string

# ===== 首次启动自动创建的管理员账号 =====
# 仅在 data/accounts.json 不存在时生效
ADMIN_USER=admin
ADMIN_PASS=admin123
